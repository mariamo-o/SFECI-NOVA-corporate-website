# .gitignore

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporary files
*.tmp
*.temp
.cache/

# Environment variables
.env
.env.local
.env.*.local

# Dependencies (if using npm in future)
node_modules/
package-lock.json
yarn.lock

# Build outputs (if minifying in future)
dist/
build/
*.min.css
*.min.js

# System files
.DS_Store
Thumbs.db
