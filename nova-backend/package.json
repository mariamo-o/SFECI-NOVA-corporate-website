{
  "name": "nova-backend",
  "version": "1.0.0",
  "description": "NOVA B2B Trade Platform — Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "migrate": "knex migrate:latest --knexfile src/db/knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile src/db/knexfile.js",
    "seed": "knex seed:run --knexfile src/db/knexfile.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/*.test.js --runInBand --forceExit",
    "test:integration": "jest tests/integration/ --runInBand --forceExit",
    "test:all": "jest --runInBand --forceExit --coverage",
    "test:auth": "jest tests/auth.test.js --runInBand --forceExit",
    "test:rfq": "jest tests/rfq.test.js --runInBand --forceExit",
    "test:vendor": "jest tests/vendor.test.js --runInBand --forceExit",
    "test:security": "jest tests/security.test.js --runInBand --forceExit",
    "test:coverage": "jest --coverage --runInBand --forceExit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.2.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "speakeasy": "^2.0.0",
    "stripe": "^14.9.0",
    "nodemailer": "^6.9.8",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 30000,
    "setupFilesAfterEnv": [
      "./tests/setup.js"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  }
}