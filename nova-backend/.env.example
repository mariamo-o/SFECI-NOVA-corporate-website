# ============================================================
# NOVA Backend — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ============================================================

# --- Application ---
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
API_VERSION=v1

# --- Database (PostgreSQL) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nova_db
DB_USER=nova_user
DB_PASSWORD=changeme_strong_password_here
DB_POOL_MIN=2
DB_POOL_MAX=10

# --- JWT ---
JWT_ACCESS_SECRET=changeme_access_secret_min_32_chars_here
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars_here
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# --- Cookie Security ---
COOKIE_SECRET=changeme_cookie_secret_min_32_chars_here
COOKIE_SECURE=false         # Set true in production (HTTPS required)
COOKIE_SAME_SITE=lax

# --- CSRF ---
CSRF_SECRET=changeme_csrf_secret_min_32_chars_here

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=900000     # 15 minutes
RATE_LIMIT_MAX_AUTH=20          # Login/register attempts per window
RATE_LIMIT_MAX_API=500          # General API calls per window

# --- File Uploads ---
UPLOAD_MAX_SIZE_MB=10
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png
UPLOAD_DIR=./uploads

# --- Email (SMTP) — scaffold only, not active without credentials ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@sfeci.com
SMTP_PASS=changeme_smtp_password
EMAIL_FROM=NOVA Platform <noreply@sfeci.com>

# --- Stripe — scaffold only, no live charges in Phase 1 ---
STRIPE_SECRET_KEY=sk_test_changeme
STRIPE_WEBHOOK_SECRET=whsec_changeme
STRIPE_CURRENCY=eur

# --- Logging ---
LOG_LEVEL=info
LOG_DIR=./logs

# --- Security ---
BCRYPT_ROUNDS=12
SESSION_SECRET=changeme_session_secret_min_32_chars

# --- 2FA (TOTP) ---
TOTP_ISSUER=NOVA Platform
TOTP_ALGORITHM=SHA1
TOTP_DIGITS=6
TOTP_PERIOD=30

# --- Governance ---
VENDOR_RISK_HIGH_THRESHOLD=70
VENDOR_RISK_MEDIUM_THRESHOLD=40
RFQ_SLA_HOURS=48
DISPUTE_SLA_HOURS=72
